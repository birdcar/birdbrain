      "Bash(less *)",
      "Bash(more *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(command *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(pwd *)",
      "Bash(whoami)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(env)",
      "Bash(env *)",
      "Bash(printenv*)",
      "Bash(uname*)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(tree*)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(ag *)",
      "Bash(fd *)",
      "Bash(diff *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(xargs *)",
      "Bash(tee *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(dig *)",
      "Bash(nslookup *)",
      "Bash(host *)",
      "Bash(ping *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(chmod *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(zip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(git *)",
